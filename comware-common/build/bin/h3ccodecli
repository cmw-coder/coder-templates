#!/bin/bash

H3C_CODE_CLI_VERSION="1.0.0"
REQUIRED_BASE_URL="http://10.113.36.145:4000"
USER_API_URL="http://10.113.36.145:5000"  # litellm_user_api 服务地址
LOG_FILE="$HOME/project/log/init_h3ccodecli.log"
BASHRC_FILE="$HOME/.bashrc"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "正在更新中，预计3~9s"

# 调用 litellm_user_api 查询用户 API Key
# 返回值通过全局变量：
#   成功: API_RESULT_KEY, API_RESULT_DEPT, API_RESULT_TEAM_ID
#   需要选择部门: API_NEED_DEPT=true, API_EXISTING_TEAMS, API_MATCHED_USERNAME
#   失败: 返回非零退出码
get_user_key_from_api() {
    local username="$1"
    local response http_code log_response

    # 清除之前的结果
    API_RESULT_KEY=""
    API_RESULT_DEPT=""
    API_RESULT_TEAM_ID=""
    API_NEED_DEPT=false
    API_EXISTING_TEAMS=""
    API_MATCHED_USERNAME=""
    API_ERROR=""

    # 调用 API（stderr 写入日志）
    response=$(curl -s -w "\n%{http_code}" \
        --connect-timeout 10 \
        --max-time 30 \
        -X POST "${USER_API_URL}/api/user/key" \
        -H "Content-Type: application/json" \
        -d "{\"username\": \"${username}\"}" 2>> "$LOG_FILE")

    # 分离响应体和状态码
    http_code=$(echo "$response" | tail -n1)
    response=$(echo "$response" | sed '$d')

    # 写入日志（脱敏处理：移除敏感字段）
    log_response=$(echo "$response" | jq -r 'del(.api_key, .key) // .' 2>/dev/null)
    echo "[API] POST /api/user/key -> HTTP $http_code" >> "$LOG_FILE"
    echo "$log_response" >> "$LOG_FILE"

    case "$http_code" in
        200)
            local success=$(echo "$response" | jq -r '.success // false' 2>/dev/null)

            if [ "$success" = "true" ]; then
                # 成功获取 API Key
                API_RESULT_KEY=$(echo "$response" | jq -r '.api_key // empty' 2>/dev/null)
                API_RESULT_DEPT=$(echo "$response" | jq -r '.department // empty' 2>/dev/null)
                API_RESULT_TEAM_ID=$(echo "$response" | jq -r '.team_id // empty' 2>/dev/null)
                return 0
            else
                # 需要选择部门
                local need_dept=$(echo "$response" | jq -r '.need_department // false' 2>/dev/null)
                if [ "$need_dept" = "true" ]; then
                    API_NEED_DEPT=true
                    # 使用 | 分隔部门名称，避免空格问题
                    API_EXISTING_TEAMS=$(echo "$response" | jq -r '.existing_teams[]?.department // empty' 2>/dev/null | tr '\n' '|')
                    API_MATCHED_USERNAME=$(echo "$response" | jq -r '.matched_username // empty' 2>/dev/null)
                    return 0
                else
                    API_ERROR=$(echo "$response" | jq -r '.message // .error // "未知错误"' 2>/dev/null)
                    return 1
                fi
            fi
            ;;
        000)
            echo -e "${RED}[Error] 无法连接到 API 服务 ($USER_API_URL)${NC}"
            echo "[Info] 请通知aigc-h25380 检查 litellm_user_api 服务是否运行"
            API_ERROR="connection_failed"
            return 1
            ;;
        401)
            echo -e "${RED}[Error] API 认证失败${NC}"
            echo "[Info] 请通知aigc-h25380"
            API_ERROR="auth_failed"
            return 1
            ;;
        4*)
            API_ERROR=$(echo "$response" | jq -r '.message // .error // "未知错误"' 2>/dev/null)
            echo -e "${RED}[Error] $API_ERROR${NC}"
            return 1
            ;;
        5*)
            echo -e "${RED}[Error] API 服务器错误 (HTTP $http_code)${NC}"
            echo "[Info] 请稍后重试"
            API_ERROR="server_error"
            return 1
            ;;
        *)
            echo -e "${RED}[Error] HTTP $http_code${NC}"
            API_ERROR="http_$http_code"
            return 1
            ;;
    esac
}

# 用户选择/输入部门后调用 API 创建用户
# 返回值通过全局变量：
#   成功: API_RESULT_KEY, API_RESULT_DEPT, API_RESULT_TEAM_ID
#   失败: 返回非零退出码
confirm_user_department() {
    local username="$1"
    local matched_username="$2"
    local department="$3"
    local response http_code log_response

    # 清除之前的结果
    API_RESULT_KEY=""
    API_RESULT_DEPT=""
    API_RESULT_TEAM_ID=""
    API_ERROR=""

    # 调用 API（stderr 写入日志）
    response=$(curl -s -w "\n%{http_code}" \
        --connect-timeout 10 \
        --max-time 30 \
        -X POST "${USER_API_URL}/api/user/key/confirm" \
        -H "Content-Type: application/json" \
        -d "{\"username\": \"${username}\", \"matched_username\": \"${matched_username}\", \"department\": \"${department}\"}" 2>> "$LOG_FILE")

    # 分离响应体和状态码
    http_code=$(echo "$response" | tail -n1)
    response=$(echo "$response" | sed '$d')

    # 写入日志（脱敏处理）
    log_response=$(echo "$response" | jq -r 'del(.api_key, .key) // .' 2>/dev/null)
    echo "[API] POST /api/user/key/confirm -> HTTP $http_code" >> "$LOG_FILE"
    echo "$log_response" >> "$LOG_FILE"

    case "$http_code" in
        200)
            local success=$(echo "$response" | jq -r '.success // false' 2>/dev/null)

            if [ "$success" = "true" ]; then
                API_RESULT_KEY=$(echo "$response" | jq -r '.api_key // empty' 2>/dev/null)
                API_RESULT_DEPT=$(echo "$response" | jq -r '.department // empty' 2>/dev/null)
                API_RESULT_TEAM_ID=$(echo "$response" | jq -r '.team_id // empty' 2>/dev/null)
                return 0
            else
                API_ERROR=$(echo "$response" | jq -r '.message // .error // "未知错误"' 2>/dev/null)
                echo -e "${RED}[Error] $API_ERROR${NC}"
                return 1
            fi
            ;;
        000)
            echo -e "${RED}[Error] 无法连接到 API 服务 ($USER_API_URL)${NC}"
            echo "[Info] 请通知aigc-h25380 检查 litellm_user_api 服务是否运行"
            API_ERROR="connection_failed"
            return 1
            ;;
        401)
            echo -e "${RED}[Error] API 认证失败${NC}"
            echo "[Info] 请通知aigc-h25380"
            API_ERROR="auth_failed"
            return 1
            ;;
        4*)
            API_ERROR=$(echo "$response" | jq -r '.message // .error // "未知错误"' 2>/dev/null)
            echo -e "${RED}[Error] $API_ERROR${NC}"
            return 1
            ;;
        5*)
            echo -e "${RED}[Error] API 服务器错误 (HTTP $http_code)${NC}"
            echo "[Info] 请稍后重试"
            API_ERROR="server_error"
            return 1
            ;;
        *)
            echo -e "${RED}[Error] HTTP $http_code${NC}"
            API_ERROR="http_$http_code"
            return 1
            ;;
    esac
}

# 从 ~/.bashrc 中删除配置标记块
remove_bashrc_config() {
    if [ -f "$BASHRC_FILE" ]; then
        sed -i '/# === H3C Code CLI Config Start ===/,/# === H3C Code CLI Config End ===/d' "$BASHRC_FILE"
    fi
}

# 从 ~/.bashrc 中读取 ANTHROPIC_AUTH_TOKEN
read_bashrc_config() {
    if [ -f "$BASHRC_FILE" ]; then
        local token=$(grep "^export ANTHROPIC_AUTH_TOKEN=" "$BASHRC_FILE" | cut -d'=' -f2 | tr -d '"')
        if [ -n "$token" ] && [ "$token" != "xx" ]; then
            export ANTHROPIC_AUTH_TOKEN="$token"
            return 0
        fi
    fi
    return 1
}

# 写入配置到 ~/.bashrc
write_bashrc_config() {
    local department="$1"
    local team_id="$2"
    local username="$3"
    local user_key="$4"
    local key_alias="$5"

    # 调试日志
    echo "[Debug] write_bashrc_config: dept=[$department] team_id=[$team_id] username=[$username] user_key=[$user_key]" >> "$LOG_FILE"
    echo "[Debug] BASHRC_FILE=[$BASHRC_FILE]" >> "$LOG_FILE"

    # 先删除旧配置块
    remove_bashrc_config

    # 检查文件是否可写
    if [ ! -w "$BASHRC_FILE" ] && [ -f "$BASHRC_FILE" ]; then
        echo "[Error] $BASHRC_FILE 不可写" >> "$LOG_FILE"
        echo -e "${RED}[Error] 配置文件不可写${NC}"
        return 1
    fi

    # 如果 bashrc 不存在，创建它
    if [ ! -f "$BASHRC_FILE" ]; then
        echo "[Debug] Creating new $BASHRC_FILE" >> "$LOG_FILE"
        touch "$BASHRC_FILE" 2>> "$LOG_FILE"
    fi

    # 追加新配置块
    {
        echo ""
        echo "# === H3C Code CLI Config Start ==="
        echo "export ANTHROPIC_AUTH_TOKEN=\"$user_key\""
        echo "export ANTHROPIC_BASE_URL=\"http://10.113.36.145:4000\""
        echo "export ANTHROPIC_MODEL=\"ComwareModel\""
        echo "export ANTHROPIC_DEFAULT_OPUS_MODEL=\"ComwareModel\""
        echo "export ANTHROPIC_DEFAULT_SONNET_MODEL=\"ComwareModel\""
        echo "export ANTHROPIC_DEFAULT_HAIKU_MODEL=\"ComwareModel-Air\""
        echo "export H3CCODECLI_VERSION=\"v0326\""
        echo "export H3C_DEPARTMENT=\"$department\""
        echo "export H3C_USERNAME=\"$username\""
        echo "export H3C_KEY_ALIAS=\"$key_alias\""
        echo "export H3C_TEAM_ID=\"$team_id\""
        echo "# === H3C Code CLI Config End ==="
    } >> "$BASHRC_FILE"

    echo "[Debug] Config written to $BASHRC_FILE" >> "$LOG_FILE"

    # 尝试 source 生效
    source ~/.bashrc 2>/dev/null
    if [ -n "$ANTHROPIC_AUTH_TOKEN" ] && [ "$ANTHROPIC_AUTH_TOKEN" = "$user_key" ]; then
        echo "[Info] 配置已生效，可直接运行 claude"
    else
        # source 失败或变量未设置，直接 export 到当前会话
        export ANTHROPIC_AUTH_TOKEN="$user_key"
        export ANTHROPIC_BASE_URL="http://10.113.36.145:4000"
        export ANTHROPIC_MODEL="ComwareModel"
        export ANTHROPIC_DEFAULT_OPUS_MODEL="ComwareModel"
        export ANTHROPIC_DEFAULT_SONNET_MODEL="ComwareModel"
        export ANTHROPIC_DEFAULT_HAIKU_MODEL="ComwareModel-Air"
        export H3CCODECLI_VERSION="v0326"
        export H3C_DEPARTMENT="$department"
        export H3C_USERNAME="$username"
        export H3C_KEY_ALIAS="$key_alias"
        export H3C_TEAM_ID="$team_id"
        echo "[Info] 配置已写入 ~/.bashrc，本次会话已生效"
        echo "[Info] 新终端将自动加载配置"
    fi
}

# 异步刷新检查 token（后台执行）
# 如果 API 返回的 apikey 或 team_id 不一致，在 bashrc 中添加刷新标记
async_refresh_check() {
    local current_token="$1"
    local current_team_id="$2"
    local username="$3"
    local user_api_url="$USER_API_URL"
    local bashrc_file="$BASHRC_FILE"
    local log_file="$LOG_FILE"

    # 后台执行检查
    (
        local response http_code api_key team_id

        response=$(curl -s -w "\n%{http_code}" \
            --connect-timeout 10 \
            --max-time 30 \
            -X POST "${user_api_url}/api/user/key" \
            -H "Content-Type: application/json" \
            -d "{\"username\": \"${username}\"}" 2>> "$log_file")

        http_code=$(echo "$response" | tail -n1)
        response=$(echo "$response" | sed '$d')

        echo "[Refresh] HTTP $http_code, URL=${user_api_url}" >> "$log_file"
        echo "[Refresh] comparing token=[$current_token] team=[$current_team_id]" >> "$log_file"

        if [ "$http_code" = "200" ]; then
            local success=$(echo "$response" | jq -r '.success // false' 2>/dev/null)
            echo "[Refresh] success=$success, response body logged" >> "$log_file"
            echo "[Refresh] Response: $response" >> "$log_file"

            if [ "$success" = "true" ]; then
                api_key=$(echo "$response" | jq -r '.api_key // empty' 2>/dev/null)
                team_id=$(echo "$response" | jq -r '.team_id // empty' 2>/dev/null)

                echo "[Refresh] API returned api_key=[$api_key] team_id=[$team_id]" >> "$log_file"

                # 检查是否不一致，在 bashrc 配置块中添加刷新标记
                # 使用英文标记避免中文编码问题
                if [ -n "$api_key" ] && [ "$api_key" != "$current_token" ]; then
                    echo "[Refresh] Token mismatch, adding refresh marker" >> "$log_file"
                    # 使用 grep 找到结束标记的行号，然后在该行前插入
                    local end_line=$(grep -n "H3C Code CLI Config End" "$bashrc_file" 2>/dev/null | head -1 | cut -d: -f1)
                    if [ -n "$end_line" ]; then
                        sed -i "${end_line}i export H3C_NEED_REFRESH=\"token_changed\"" "$bashrc_file"
                        echo "[Refresh] Marker inserted at line $end_line" >> "$log_file"
                    else
                        echo "[Refresh] ERROR: End marker not found in bashrc" >> "$log_file"
                    fi
                elif [ -n "$team_id" ] && [ -n "$current_team_id" ] && [ "$team_id" != "$current_team_id" ]; then
                    echo "[Refresh] Team ID mismatch, adding refresh marker" >> "$log_file"
                    local end_line=$(grep -n "H3C Code CLI Config End" "$bashrc_file" 2>/dev/null | head -1 | cut -d: -f1)
                    if [ -n "$end_line" ]; then
                        sed -i "${end_line}i export H3C_NEED_REFRESH=\"team_changed\"" "$bashrc_file"
                        echo "[Refresh] Marker inserted at line $end_line" >> "$log_file"
                    else
                        echo "[Refresh] ERROR: End marker not found in bashrc" >> "$log_file"
                    fi
                else
                    echo "[Refresh] Config match or empty team_id, no refresh needed" >> "$log_file"
                fi
            else
                echo "[Refresh] API returned success=false" >> "$log_file"
            fi
        else
            echo "[Refresh] API call failed (HTTP $http_code)" >> "$log_file"
        fi
    ) &
}

# 检查并设置 Base URL
ensure_base_url() {
    if [ "$ANTHROPIC_BASE_URL" != "$REQUIRED_BASE_URL" ]; then
        export ANTHROPIC_BASE_URL="$REQUIRED_BASE_URL"
    fi
}

# 检查 token 是否有效
is_token_valid() {
    [ -n "$ANTHROPIC_AUTH_TOKEN" ] && [ "$ANTHROPIC_AUTH_TOKEN" != "xx" ]
}

# 主逻辑：设置认证 token
setup_auth_token() {
    # 检查 bashrc 中是否有刷新标记（上次异步检查发现不一致）
    local need_refresh=$(grep "^export H3C_NEED_REFRESH=" "$BASHRC_FILE" 2>/dev/null | cut -d'=' -f2 | tr -d '"')
    if [ -n "$need_refresh" ]; then
        echo "[Info] 检测到配置变更 ($need_refresh)，正在重新获取..."
        # remove_bashrc_config 会删除整个配置块（包括刷新标记）
        remove_bashrc_config
        # 继续执行后续逻辑重新获取
    else
        # 如果环境变量中已有有效 token，直接使用并启动异步刷新检查
        if is_token_valid; then
            local current_team_id=$(grep "^export H3C_TEAM_ID=" "$BASHRC_FILE" 2>/dev/null | cut -d'=' -f2 | tr -d '"')
            local username=$(whoami)
            # 启动异步刷新检查
            async_refresh_check "$ANTHROPIC_AUTH_TOKEN" "$current_team_id" "$username"
            return 0
        fi

        # 尝试从 ~/.bashrc 读取配置
        if read_bashrc_config; then
            # 从 bashrc 读取用户信息用于显示
            local saved_username=$(grep "^export H3C_USERNAME=" "$BASHRC_FILE" | cut -d'=' -f2 | tr -d '"')
            local saved_dept=$(grep "^export H3C_DEPARTMENT=" "$BASHRC_FILE" | cut -d'=' -f2 | tr -d '"')
            local saved_team_id=$(grep "^export H3C_TEAM_ID=" "$BASHRC_FILE" 2>/dev/null | cut -d'=' -f2 | tr -d '"')
            echo "[Info] 域账号: $saved_username"
            echo "[Info] 部门: $saved_dept"
            echo "[Info] 个人 API Key: $ANTHROPIC_AUTH_TOKEN"
            # 启动异步刷新检查
            async_refresh_check "$ANTHROPIC_AUTH_TOKEN" "$saved_team_id" "$saved_username"
            return 0
        fi
    fi

    # 获取系统用户名作为域账号
    local username=$(whoami)

    echo "[Info] 正在获取用户信息..."

    # 调用 API 获取用户信息
    if ! get_user_key_from_api "$username"; then
        echo -e "${RED}[Error] 获取用户信息失败${NC}"
        exit 1
    fi

    # 检查是否需要选择部门
    if [ "$API_NEED_DEPT" = "true" ]; then
        # 显示部门选择菜单
        echo ""
        echo "================================================="
        echo "[Info] 请选择或输入您的部门："
        echo "================================================="

        # 将部门列表转换为数组（使用 | 分隔符）
        local teams=()
        if [ -n "$API_EXISTING_TEAMS" ]; then
            IFS='|' read -ra teams <<< "$API_EXISTING_TEAMS"
        fi

        local i=1
        for team in "${teams[@]}"; do
            [ -n "$team" ] && echo "  $i. $team"
            ((i++))
        done
        echo "================================================="

        local department=""
        while true; do
            printf "请输入序号选择现有部门，或直接输入新部门英文简称: "
            read -r input

            if [[ -z "$input" ]]; then
                echo -e "${YELLOW}[Warn] 输入不能为空${NC}"
                continue
            fi

            # 检查是否为数字
            if [[ "$input" =~ ^[0-9]+$ ]]; then
                # 数字输入，选择现有部门
                if [[ "$input" -ge 1 && "$input" -le ${#teams[@]} ]]; then
                    department="${teams[$((input-1))]}"
                    break
                else
                    echo -e "${YELLOW}[Warn] 无效序号，请重新输入${NC}"
                    continue
                fi
            else
                # 文本输入，作为新部门名
                department="$input"
                break
            fi
        done

        # 确认部门创建用户
        local matched_username="${API_MATCHED_USERNAME:-$username}"
        if ! confirm_user_department "$username" "$matched_username" "$department"; then
            echo -e "${RED}[Error] 创建用户失败${NC}"
            exit 1
        fi
    fi

    # 从 API 结果获取信息
    local user_key="${API_RESULT_KEY}"
    local dept="${API_RESULT_DEPT}"
    local team_id="${API_RESULT_TEAM_ID}"

    if [[ -z "$user_key" ]]; then
        echo -e "${RED}[Error] 未获取到 API Key${NC}"
        exit 1
    fi

    # 保存配置到 ~/.bashrc
    write_bashrc_config "$dept" "$team_id" "$username" "$user_key" ""

    echo ""
    echo -e "${GREEN}[Info] 用户信息获取成功！${NC}"
    echo "[Info] 域账号: $username"
    echo "[Info] 部门: $dept"
    echo "[Info] 个人 API Key: $user_key"
}

# 处理命令行参数
if [ "$1" = "--reset" ]; then
    remove_bashrc_config
    echo "[Info] 配置已清除"
    echo "[Info] 请运行 source ~/.bashrc 或重新打开终端使更改生效"
    exit 0
fi

# 创建日志目录
mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || {
    echo "[Warn] 无法创建日志目录: $(dirname "$LOG_FILE")"
}

# 检查核心依赖（必须在 API 调用之前）
check_core_deps() {
    local missing=()
    for cmd in curl jq; do
        if ! command -v "$cmd" &> /dev/null; then
            missing+=("$cmd")
        fi
    done
    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "${RED}[Error] 缺少必要依赖: ${missing[*]}${NC}"
        echo "[Info] 请安装后重试: apt install ${missing[*]} -y"
        exit 1
    fi
}
check_core_deps

# 定义要写入的JSON内容（包含所有需要安装的 plugin）
JSON_CONTENT='{
  "enabledPlugins": {
    "comware-plugin@comware-plugins-marketplace": true
  }
}'

# 定义两个目标文件路径
GLOBAL_SETTINGS="$HOME/.claude/settings.json"  # 全局用户级路径
LOCAL_SETTINGS="$HOME/project/.claude/settings.json"  # 本地覆盖级路径

# 函数：写入JSON到指定文件（自动创建目录）
write_json_to_file() {
  local file_path="$1"
  local json="$2"

  # 创建文件所在的目录（如果不存在）
  local dir_path=$(dirname "$file_path")
  if [ ! -d "$dir_path" ]; then
    echo "创建目录: $dir_path"
    if ! mkdir -p "$dir_path"; then
      echo "错误：无法创建目录 $dir_path"
      return 1
    fi
  fi

  # 将JSON内容写入文件（覆盖原有内容）
  if echo "$json" > "$file_path"; then
    echo "成功写入文件: $file_path"
    return 0
  else
    echo "错误：无法写入文件 $file_path"
    return 1
  fi
}

# 执行写入操作（日志输出到文件）
{
    echo "写入配置文件..."
    write_json_to_file "$GLOBAL_SETTINGS" "$JSON_CONTENT"
    write_json_to_file "$LOCAL_SETTINGS" "$JSON_CONTENT"

    # 最终检查
    echo -e "\n验证文件是否存在："
    [ -f "$GLOBAL_SETTINGS" ] && echo "✅ 全局配置文件已存在: $GLOBAL_SETTINGS" || echo "❌ 全局配置文件创建失败"
    [ -f "$LOCAL_SETTINGS" ] && echo "✅ 本地配置文件已存在: $LOCAL_SETTINGS" || echo "❌ 本地配置文件创建失败"

    echo -e "\n操作完成！"
} >> "$LOG_FILE" 2>&1


# 检查并安装依赖（日志输出到文件）
check_and_install_deps() {
    local deps=("curl" "jq" "git")
    local to_install=()

    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &> /dev/null; then
            to_install+=("$dep")
        fi
    done

    if [ ${#to_install[@]} -gt 0 ]; then
        echo "[Info] 正在安装依赖: ${to_install[*]}"
        if command -v sudo &> /dev/null; then
            sudo apt update && sudo apt install "${to_install[@]}" -y
        else
            apt update && apt install "${to_install[@]}" -y
        fi
    fi
}

{
    check_and_install_deps

    # 函数：检查 marketplace 是否已安装
    is_marketplace_installed() {
        local name="$1"
        claude plugin marketplace list 2>/dev/null | grep -q "$name"
    }

    # 函数：添加或更新 marketplace
    add_or_update_marketplace() {
        local url="$1"
        local name="$2"

        if is_marketplace_installed "$name"; then
            echo "[Info] Marketplace '$name' 已安装，正在更新..."
            claude plugin marketplace update "$name" 2>/dev/null
        else
            echo "[Info] 正在添加 marketplace: $name"
            claude plugin marketplace add "$url"
        fi
    }

    # 添加或更新 marketplace
    add_or_update_marketplace "http://10.113.36.121:3001/chatgpt/comware-plugins-marketplace.git" "comware-plugins-marketplace"
    add_or_update_marketplace "http://10.113.36.121:3001/chatgpt/claude-plugins.git" "comware-plugins"

    # 安装并更新 plugins
    echo "[Info] 安装/更新 plugins..."
    claude plugin install comware-plugin@comware-plugins-marketplace -s project


    # 更新 plugins
    echo "[Info] 检查 plugin 更新..."
    claude plugin update comware-plugin@comware-plugins-marketplace -s project


    # 清理旧技能文件
    rm -rf ~/project/.claude/skills/generating-comware-buildrun 2>/dev/null
} >> "$LOG_FILE" 2>&1


# install claude code
{
    sudo npm install -g @anthropic-ai/claude-code
} >> "$LOG_FILE" 2>&1



# ============================================================
# 主程序开始
# ============================================================


# 强制设置正确的 Base URL
ensure_base_url

# 设置认证 token
setup_auth_token

# 其他环境变量配置
export CLAUDE_SESSION_START=$(date +%s)
export DISABLE_AUTOUPDATER=1
export API_TIMEOUT_MS=30000000

# Telemetry configs
export CLAUDE_CODE_ENABLE_TELEMETRY="1"
export OTEL_METRICS_EXPORTER="otlp,prometheus"
export OTEL_LOGS_EXPORTER="otlp"
export OTEL_EXPORTER_OTLP_PROTOCOL="grpc"
export OTEL_EXPORTER_OTLP_ENDPOINT="http://10.113.36.125:4000"

# Debug configs
export OTEL_METRIC_EXPORT_INTERVAL="100000"
export OTEL_LOGS_EXPORT_INTERVAL="50000"

# Startup message
echo ""
echo "================================================="
echo "[Info] H3C CODE CLI v${H3C_CODE_CLI_VERSION}"
echo "[Info] Input your request in the terminal"
echo "================================================="
echo ""

# Start Claude
claude --allowedTools "Bash,Read"  --ide  --permission-mode acceptEdits --model opusplan --dangerously-skip-permissions

# Finish message
echo ""
echo "================================================"
echo "[Info] H3C Code CLI v${H3C_CODE_CLI_VERSION} finished"
echo "================================================"
echo ""