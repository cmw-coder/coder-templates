#!/bin/bash

H3C_CODE_CLI_VERSION="1.0.0"

# Model configs
export ANTHROPIC_BASE_URL="http://10.113.36.145:8090"
export ANTHROPIC_AUTH_TOKEN="xx"
export ANTHROPIC_MODEL="deepseek-v3"
export ANTHROPIC_DEFAULT_OPUS_MODEL="deepseek-v3"
export ANTHROPIC_DEFAULT_SONNET_MODEL="deepseek-v3"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="deepseek-v3"
export ANTHROPIC_SMALL_FAST_MODEL="deepseek-v3"
# export CLAUDE_CODE_MAX_OUTPUT_TOKENS=50000
export CLAUDE_SESSION_START=$(date +%s)
export DISABLE_AUTOUPDATER=1 
export API_TIMEOUT_MS=30000000

# Telemetry configs
export CLAUDE_CODE_ENABLE_TELEMETRY="1"
export OTEL_METRICS_EXPORTER="otlp,prometheus"
export OTEL_LOGS_EXPORTER="otlp"
export OTEL_EXPORTER_OTLP_PROTOCOL="grpc"
export OTEL_EXPORTER_OTLP_ENDPOINT="http://10.113.36.125:4000"

# Debug configs
export OTEL_METRIC_EXPORT_INTERVAL="100000"
export OTEL_LOGS_EXPORT_INTERVAL="50000"

# Startup message
echo ""
echo "================================================="
echo "[Info] H3C CODE CLI v${H3C_CODE_CLI_VERSION}"
echo "[Info] Input your request in the terminal"
echo "================================================="
echo ""

# Start Claude
claude --allowedTools "Bash,Read" --permission-mode acceptEdits --model opusplan --dangerously-skip-permissions

# Finish message
echo ""
echo "================================================"
echo "[Info] H3C Code CLI v${H3C_CODE_CLI_VERSION} finished"
echo "================================================"
echo ""
