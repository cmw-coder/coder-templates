# Force LF line endings for all text files
* text=auto eol=lf

# Binary files - do not modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar.gz binary
*.tgz binary

# Office files - do not modify
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
*.pdf binary

# Certificate files (PEM-encoded text, safe to normalize)
*.crt text eol=lf
*.pem text eol=lf
*.key text eol=lf
