#!/bin/bash
# Navigation aliases
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Common command aliases
alias ls='ls --color=auto' # Enable colored output for ls
alias ll='ls -alF' # Long listing format
alias la='ls -A' # List all files including hidden ones
alias rm='rm -i' # Prompt before deleting
alias cp='cp -i' # Prompt before overwriting
alias mv='mv -i' # Prompt before overwriting

# Source SVN project configuration if available
if [ -f "${HOME}/.svn_project_env" ]; then
    # shellcheck source=/dev/null
    source "${HOME}/.svn_project_env"
fi
