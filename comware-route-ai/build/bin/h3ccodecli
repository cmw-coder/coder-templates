#!/bin/bash

H3C_CODE_CLI_VERSION="1.0.0"
REQUIRED_BASE_URL="http://10.113.12.131:4000"
REQUIRED_API_KEY="sk-9i1wGrbXNDFZuHGDyKUt6g"
REQUIRED_MODEL="Qwen3.5-397B-A17B-GPTQ-Int4"
LOG_FILE="$HOME/project/log/init_h3ccodecli.log"
BASHRC_FILE="$HOME/.bashrc"

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "Initializing, estimated 3~9s"

# Remove config block from ~/.bashrc
remove_bashrc_config() {
    if [ -f "$BASHRC_FILE" ]; then
        sed -i '/# === H3C Code CLI Config Start ===/,/# === H3C Code CLI Config End ===/d' "$BASHRC_FILE"
    fi
}

# Read ANTHROPIC_API_KEY from ~/.bashrc
read_bashrc_config() {
    if [ -f "$BASHRC_FILE" ]; then
        local key
        key=$(grep "^export ANTHROPIC_API_KEY=" "$BASHRC_FILE" | cut -d'=' -f2 | tr -d '"')
        if [ -n "$key" ] && [ "$key" = "$REQUIRED_API_KEY" ]; then
            export ANTHROPIC_API_KEY="$key"
            return 0
        fi
    fi
    return 1
}

# Write config to ~/.bashrc
write_bashrc_config() {
    local username="$1"

    echo "[Debug] write_bashrc_config: username=[$username]" >> "$LOG_FILE"
    echo "[Debug] BASHRC_FILE=[$BASHRC_FILE]" >> "$LOG_FILE"

    # Remove old config block first
    remove_bashrc_config

    # Check if file is writable
    if [ ! -w "$BASHRC_FILE" ] && [ -f "$BASHRC_FILE" ]; then
        echo "[Error] $BASHRC_FILE is not writable" >> "$LOG_FILE"
        echo -e "${RED}[Error] Config file is not writable${NC}"
        return 1
    fi

    # Create bashrc if it doesn't exist
    if [ ! -f "$BASHRC_FILE" ]; then
        echo "[Debug] Creating new $BASHRC_FILE" >> "$LOG_FILE"
        touch "$BASHRC_FILE" 2>> "$LOG_FILE"
    fi

    # Append new config block
    {
        echo ""
        echo "# === H3C Code CLI Config Start ==="
        echo "export ANTHROPIC_API_KEY=\"$REQUIRED_API_KEY\""
        echo "export ANTHROPIC_BASE_URL=\"$REQUIRED_BASE_URL\""
        echo "export ANTHROPIC_MODEL=\"$REQUIRED_MODEL\""
        echo "export ANTHROPIC_DEFAULT_OPUS_MODEL=\"$REQUIRED_MODEL\""
        echo "export ANTHROPIC_DEFAULT_SONNET_MODEL=\"$REQUIRED_MODEL\""
        echo "export ANTHROPIC_DEFAULT_HAIKU_MODEL=\"$REQUIRED_MODEL\""
        echo "export H3CCODECLI_VERSION=\"v0326\""
        echo "export H3C_DEPARTMENT=\"Routing&MPLS\""
        echo "export H3C_USERNAME=\"$username\""
        echo "# === H3C Code CLI Config End ==="
    } >> "$BASHRC_FILE"

    echo "[Debug] Config written to $BASHRC_FILE" >> "$LOG_FILE"

    # Try to source config
    source ~/.bashrc 2>/dev/null
    if [ -n "$ANTHROPIC_API_KEY" ] && [ "$ANTHROPIC_API_KEY" = "$REQUIRED_API_KEY" ]; then
        echo "[Info] Config applied, ready to run claude"
    else
        # Source failed, export directly to current session
        export ANTHROPIC_API_KEY="$REQUIRED_API_KEY"
        export ANTHROPIC_BASE_URL="$REQUIRED_BASE_URL"
        export ANTHROPIC_MODEL="$REQUIRED_MODEL"
        export ANTHROPIC_DEFAULT_OPUS_MODEL="$REQUIRED_MODEL"
        export ANTHROPIC_DEFAULT_SONNET_MODEL="$REQUIRED_MODEL"
        export ANTHROPIC_DEFAULT_HAIKU_MODEL="$REQUIRED_MODEL"
        export H3CCODECLI_VERSION="v0326"
        export H3C_DEPARTMENT="Routing&MPLS"
        export H3C_USERNAME="$username"
        echo "[Info] Config written to ~/.bashrc and applied to current session"
        echo "[Info] New terminals will load config automatically"
    fi
}

# Ensure Base URL is set correctly
ensure_base_url() {
    if [ "$ANTHROPIC_BASE_URL" != "$REQUIRED_BASE_URL" ]; then
        export ANTHROPIC_BASE_URL="$REQUIRED_BASE_URL"
    fi
}

# Ensure API Key is set correctly
ensure_api_key() {
    if [ "$ANTHROPIC_API_KEY" != "$REQUIRED_API_KEY" ]; then
        export ANTHROPIC_API_KEY="$REQUIRED_API_KEY"
    fi
}

# Main logic: setup auth config
setup_auth_config() {
    # If bashrc already has the correct config, just load it
    if read_bashrc_config; then
        local saved_username
        saved_username=$(grep "^export H3C_USERNAME=" "$BASHRC_FILE" | cut -d'=' -f2 | tr -d '"')
        echo "[Info] Username: $saved_username"
        echo "[Info] Department: Routing&MPLS"
        echo "[Info] API Key: $ANTHROPIC_API_KEY"
        return 0
    fi

    # Write new config
    local username
    username=$(whoami)
    write_bashrc_config "$username"

    echo ""
    echo -e "${GREEN}[Info] Config initialized!${NC}"
    echo "[Info] Username: $username"
    echo "[Info] Department: Routing&MPLS"
    echo "[Info] API Key: $REQUIRED_API_KEY"
}

# Handle command line arguments
if [ "$1" = "--reset" ]; then
    remove_bashrc_config
    echo "[Info] Config cleared"
    echo "[Info] Run source ~/.bashrc or reopen terminal to apply changes"
    exit 0
fi

# Create log directory
mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || {
    echo "[Warn] Cannot create log directory: $(dirname "$LOG_FILE")"
}

# Check core dependencies
check_core_deps() {
    local missing=()
    for cmd in curl jq; do
        if ! command -v "$cmd" &> /dev/null; then
            missing+=("$cmd")
        fi
    done
    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "${RED}[Error] Missing dependencies: ${missing[*]}${NC}"
        echo "[Info] Install them first: apt install ${missing[*]} -y"
        exit 1
    fi
}
check_core_deps

# Define JSON content for Claude plugin settings
JSON_CONTENT='{
  "enabledPlugins": {
    "comware-plugin@comware-plugins-marketplace": true
  }
}'

# Define target file paths
GLOBAL_SETTINGS="$HOME/.claude/settings.json"  # Global user-level path
LOCAL_SETTINGS="$HOME/project/.claude/settings.json"  # Local override path

# Function: write JSON to file (auto-create directory)
write_json_to_file() {
  local file_path="$1"
  local json="$2"

  local dir_path
  dir_path=$(dirname "$file_path")
  if [ ! -d "$dir_path" ]; then
    echo "Creating directory: $dir_path"
    if ! mkdir -p "$dir_path"; then
      echo "Error: cannot create directory $dir_path"
      return 1
    fi
  fi

  if echo "$json" > "$file_path"; then
    echo "Written file: $file_path"
    return 0
  else
    echo "Error: cannot write file $file_path"
    return 1
  fi
}

# Write settings files (log output to file)
{
    echo "Writing config files..."
    write_json_to_file "$GLOBAL_SETTINGS" "$JSON_CONTENT"
    write_json_to_file "$LOCAL_SETTINGS" "$JSON_CONTENT"

    echo -e "\nVerifying files:"
    [ -f "$GLOBAL_SETTINGS" ] && echo "OK: Global config exists: $GLOBAL_SETTINGS" || echo "FAIL: Global config missing"
    [ -f "$LOCAL_SETTINGS" ] && echo "OK: Local config exists: $LOCAL_SETTINGS" || echo "FAIL: Local config missing"

    echo -e "\nDone!"
} >> "$LOG_FILE" 2>&1


# Check and install dependencies (log output to file)
check_and_install_deps() {
    local deps=("curl" "jq" "git")
    local to_install=()

    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &> /dev/null; then
            to_install+=("$dep")
        fi
    done

    if [ ${#to_install[@]} -gt 0 ]; then
        echo "[Info] Installing dependencies: ${to_install[*]}"
        if command -v sudo &> /dev/null; then
            sudo apt update && sudo apt install "${to_install[@]}" -y
        else
            apt update && apt install "${to_install[@]}" -y
        fi
    fi
}

{
    check_and_install_deps

    # Function: check if marketplace is installed
    is_marketplace_installed() {
        local name="$1"
        claude plugin marketplace list 2>/dev/null | grep -q "$name"
    }

    # Function: add or update marketplace
    add_or_update_marketplace() {
        local url="$1"
        local name="$2"

        if is_marketplace_installed "$name"; then
            echo "[Info] Marketplace '$name' already installed, updating..."
            claude plugin marketplace update "$name" 2>/dev/null
        else
            echo "[Info] Adding marketplace: $name"
            claude plugin marketplace add "$url"
        fi
    }

    # Add or update marketplaces
    add_or_update_marketplace "http://10.113.36.121:3001/chatgpt/comware-plugins-marketplace.git" "comware-plugins-marketplace"
    add_or_update_marketplace "http://10.113.36.121:3001/chatgpt/claude-plugins.git" "comware-plugins"

    # Install and update plugins
    echo "[Info] Installing/updating plugins..."
    claude plugin install comware-plugin@comware-plugins-marketplace -s project

    # Update plugins
    echo "[Info] Checking plugin updates..."
    claude plugin update comware-plugin@comware-plugins-marketplace -s project

    # Clean up old skill files
    rm -rf ~/project/.claude/skills/generating-comware-buildrun 2>/dev/null
} >> "$LOG_FILE" 2>&1


# Install claude code
{
    sudo npm install -g @anthropic-ai/claude-code
} >> "$LOG_FILE" 2>&1



# ============================================================
# Main program starts
# ============================================================


# Force correct Base URL and API Key
ensure_base_url
ensure_api_key

# Setup auth config
setup_auth_config

# Other environment variable configs
export CLAUDE_SESSION_START=$(date +%s)
export DISABLE_AUTOUPDATER=1
export API_TIMEOUT_MS=30000000

# Telemetry configs
export CLAUDE_CODE_ENABLE_TELEMETRY="1"
export OTEL_METRICS_EXPORTER="otlp,prometheus"
export OTEL_LOGS_EXPORTER="otlp"
export OTEL_EXPORTER_OTLP_PROTOCOL="grpc"
export OTEL_EXPORTER_OTLP_ENDPOINT="http://10.113.36.125:4000"

# Debug configs
export OTEL_METRIC_EXPORT_INTERVAL="100000"
export OTEL_LOGS_EXPORT_INTERVAL="50000"

# Startup message
echo ""
echo "================================================="
echo "[Info] H3C CODE CLI v${H3C_CODE_CLI_VERSION}"
echo "[Info] Input your request in the terminal"
echo "================================================="
echo ""

# Start Claude
claude --allowedTools "Bash,Read"  --ide  --permission-mode acceptEdits --model opusplan --dangerously-skip-permissions

# Finish message
echo ""
echo "================================================"
echo "[Info] H3C Code CLI v${H3C_CODE_CLI_VERSION} finished"
echo "================================================"
echo ""
